{
  "source_repo": "jsdfhasuh/emo-vision-train",
  "python_version": "3.11",
  "release_asset_name": "training_platform-windows-${RELEASE_TAG}.zip",
  "ci_extra_packages": [
    "torchvision==0.20.1",
    "onnxruntime-gpu==1.23.2",
    "kagglesdk==0.1.31"
  ],
  "entry": "${SOURCE_ROOT}/main.py",
  "name": "training_platform",
  "onefile": false,
  "console": true,
  "icon": null,
  "add_data": [
    "${SOURCE_ROOT}/ui:ui",
    "${SOURCE_ROOT}/my_ultralytics_func:my_ultralytics_func",
    "${SOURCE_ROOT}/ultralytics/ultralytics:ultralytics",
    "${SOURCE_ROOT}/training_platform.ui:.",
    "${SOURCE_ROOT}/tool.py:.",
    "${SOURCE_ROOT}/static:static",
    "${SOURCE_ROOT}/kaggle_func/templates:kaggle_func\\templates",
    "${SOURCE_ROOT}/X-AnyLabeling/anylabeling:X-AnyLabeling\\anylabeling"
  ],
  "hidden_imports": [
    "PyQt5",
    "PyQt5.QtCore",
    "PyQt5.QtGui",
    "PyQt5.QtWidgets",
    "PyQt5.uic",
    "PyQt5.QtWebEngine",
    "PyQt5.QtWebEngineWidgets",
    "torch",
    "torchvision",
    "cv2",
    "numpy",
    "PIL",
    "polars",
    "yaml",
    "onnx",
    "onnxruntime",
    "qimage2ndarray",
    "natsort",
    "termcolor",
    "lapx",
    "scipy",
    "shapely",
    "psutil",
    "pyclipper",
    "tokenizers",
    "jsonlines",
    "json_repair",
    "kaggle",
    "importlib_metadata",
    "markdown",
    "requests",
    "tqdm",
    "six",
    "openai",
    "termcolor"
  ],
  "excludes": [],
  "collect_binaries": ["torch", "torchvision"],
  "extra_args": [
    "--copy-metadata",
    "torch",
    "--copy-metadata",
    "torchvision",
    "--copy-metadata",
    "onnx",
    "--copy-metadata",
    "onnxruntime",
    "--copy-metadata",
    "onnxruntime-gpu",
    "--collect-all",
    "kaggle",
    "--collect-all",
    "kagglesdk",
    "--copy-metadata",
    "kaggle",
    "--copy-metadata",
    "kagglesdk"
  ],
  "updater": {
    "enabled": true,
    "entry": "${SOURCE_ROOT}/updater.py",
    "name": "updater",
    "onefile": true,
    "console": true,
    "hidden_imports": [],
    "extra_args": []
  }
}
